# Flask
FLASK_SECRET_KEY=changeme-local
SESSION_COOKIE_SECURE=false
PUBLIC_BASE_URL=

# Auto renewal
AUTO_RENEW_DAYS_BEFORE=30
AUTO_RENEW_INTERVAL_HOURS=12

# Certbot paths
CERTBOT_CONFIG_DIR=/etc/letsencrypt
CERTBOT_WORK_DIR=/var/lib/letsencrypt
CERTBOT_LOGS_DIR=/var/log/letsencrypt

# Initial allowed user (bootstrapped at startup)
INITIAL_ALLOWED_USER_EMAIL=tu.usuario@gmail.com
INITIAL_ALLOWED_USER_ROLE=admin

# Google OAuth
# In Google Cloud Console configure redirect URI based on your public base URL.
# Local example: http://localhost:8080/auth/google/callback
# Prod example: https://certpanel.confiber.com.ar/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DISCOVERY_URL=https://accounts.google.com/.well-known/openid-configuration
